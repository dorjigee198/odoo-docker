<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_check_overdue_tickets" model="ir.cron">
        <field name="name">Customer Support: Check Overdue Tickets</field>
        <field name="model_id" ref="model_customer_support"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_overdue_tickets()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_check_sla_breaches" model="ir.cron">
        <field name="name">Customer Support: Check SLA Breaches</field>
        <field name="model_id" ref="model_customer_support"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_sla_breaches()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
