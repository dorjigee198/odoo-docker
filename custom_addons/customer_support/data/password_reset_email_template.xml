<odoo>
    <record id="mail_template_customer_support_password_reset" model="mail.template">
        <field name="name">Customer Support Password Reset</field>
        <field name="model_id" ref="base.model_res_users" />
        <field name="subject">Reset your Customer Support password</field>
        <field name="email_from">{{ object.company_id.email_formatted or object.email_formatted }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="auto_delete" eval="True" />
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif;font-size:14px;color:#1f2937;line-height:1.5;">
                <p>Hello <t t-out="ctx.get('cs_user_name') or object.name" />,</p>
                <p>We received a request to reset your Customer Support password.</p>
                <p>
                    <a t-att-href="ctx.get('cs_reset_link')"
                        style="display:inline-block;padding:10px 16px;border-radius:6px;background:#0c4a6e;color:#fff;text-decoration:none;">
                        Reset Password
                    </a>
                </p>
                <p>If the button does not work, copy and paste this link into your browser:</p>
                <p>
                    <a t-att-href="ctx.get('cs_reset_link')">
                        <t t-out="ctx.get('cs_reset_link')" />
                    </a>
                </p>
                <p>If you did not request this change, you can ignore this email.</p>
            </div>
        </field>
    </record>
</odoo>