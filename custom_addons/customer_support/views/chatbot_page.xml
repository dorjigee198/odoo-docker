<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="chatbot_page" name="Dragon Coders AI Chatbot">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <title>Dragon Coders AI Chatbot</title>

                <!-- Bootstrap 5 CSS -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
                    rel="stylesheet" />
                <link
                    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
                    rel="stylesheet" />

                <!-- Custom CSS -->
                <link rel="stylesheet"
                    href="/customer_support/static/src/css/portal_dashboard.css?v=4" />
                <link rel="stylesheet" href="/customer_support/static/src/css/chatbot.css" />
                <link rel="stylesheet"
                    href="/customer_support/static/src/css/portal_dashboard_mobile.css?v=5" />

                <style>
                    .notif-item {
                    display: flex; align-items: flex-start; gap: 0.75rem;
                    padding: 0.75rem 1rem; border-bottom: 1px solid rgba(5,150,105,0.07);
                    cursor: default;
                    }
                    .notif-item:last-child { border-bottom: none; }
                    .notif-icon-wrap {
                    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
                    display: flex; align-items: center; justify-content: center; font-size: .9rem;
                    }
                    .notif-icon-wrap.status { background: rgba(5,150,105,.12); color: #059669; }
                    .notif-icon-wrap.assigned { background: rgba(22,163,74,.12); color: #16a34a; }
                    .notif-icon-wrap.breach { background: rgba(239,68,68,.12); color: #ef4444; }
                    .notif-body { flex: 1; min-width: 0; }
                    .notif-title {
                    font-size: .8rem; font-weight: 700; color: #065f46;
                    margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow:
                    ellipsis;
                    }
                    .notif-sub {
                    font-size: .78rem; color: #475569; line-height: 1.4;
                    word-break: break-word; white-space: normal;
                    }
                    .notif-time-text { font-size: .7rem; color: #94a3b8; margin-top: 3px; }
                    .notif-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
                    margin-top: 6px; }
                    .notif-dot.status { background: #059669; }
                    .notif-dot.assigned { background: #16a34a; }
                    .notif-dot.breach { background: #ef4444; }
                </style>
            </t>

            <div class="dashboard-wrapper">
                <!-- Top Navigation Header -->
                <header class="dashboard-header">
                    <div class="header-content">

                        <!-- ↓ MOBILE NAV COMPONENT (hamburger + drawer) -->
                        <t t-set="mobile_active_page" t-value="'faq'" />
                        <t t-call="customer_support.portal_mobile_nav_component" />

                        <div class="header-nav">
                            <a href="/customer_support/dashboard" class="nav-link">
                                <i class="bi bi-speedometer2 me-2"></i>Overview </a>
                            <a href="/customer_support/tickets/list" class="nav-link">
                                <i class="bi bi-ticket-detailed me-2"></i>Tickets </a>
                            <a href="/customer_support/dashboard#reporting" class="nav-link">
                                <i class="bi bi-folder-fill me-2"></i>Reports </a>
                            <a href="/customer_support/chatbot" class="nav-link active">
                                <i class="bi bi-chat-dots me-2"></i>FAQ </a>
                        </div>
                        <div class="header-right">
                            <div class="header-actions">
                                <a href="/customer_support/create_ticket" class="btn-new-ticket">
                                    <i class="bi bi-plus-circle me-2"></i>New Ticket </a>
                            </div>

                            <!-- User Profile -->
                            <div class="user-profile dropdown">
                                <!-- NOTIFICATION BELL -->
                                <div class="notif-wrap me-3">
                                    <button class="notif-btn" id="chatbotNotifBell"
                                        title="Notifications">
                                        <i class="bi bi-bell-fill"></i>
                                        <span class="notif-badge d-none" id="chatbotNotifBadge">0</span>
                                    </button>
                                    <div class="notif-dropdown" id="chatbotNotifDropdown">
                                        <div class="notif-header">
                                            <h6><i class="bi bi-bell me-2" style="color:#059669;"></i>
                                                Notifications</h6>
                                            <button class="notif-mark-read" id="chatbotMarkRead">Mark
                                                all read</button>
                                        </div>
                                        <div class="notif-list" id="chatbotNotifList">
                                            <div class="notif-empty">
                                                <i class="bi bi-arrow-repeat"
                                                    style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>
                                                Loading... </div>
                                        </div>
                                        <div class="notif-footer">
                                            <a href="/customer_support/tickets">View my tickets
                                                &#8594;</a>
                                        </div>
                                    </div>
                                </div>

                                <a class="d-flex align-items-center text-white dropdown-toggle"
                                    href="#"
                                    id="userProfileDropdown"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="text-decoration: none;">

                                    <span class="user-name me-3">
                                        <t t-esc="request.env.user.name" />
                                    </span>

                                    <img
                                        t-att-src="'/web/image/res.users/%s/avatar_128' % request.env.user.id"
                                        alt="User Avatar"
                                        class="user-avatar"
                                        onerror="this.src='/web/static/img/avatar_gray.svg'" />
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end"
                                    aria-labelledby="userProfileDropdown">
                                    <li>
                                        <a class="dropdown-item" href="/customer_support/profile">
                                            <i class="bi bi-person me-2"></i> Edit Profile </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger"
                                            href="/customer_support/logout_manual">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Chatbot Content -->
                <div class="dashboard-content">
                    <div class="chat-container">

                        <div id="chat-box" class="chat-box"></div>

                        <div class="quick-replies">
                            <button class="quick-reply" data-msg="Services">Services</button>
                            <button class="quick-reply" data-msg="Pricing">Pricing</button>
                            <button class="quick-reply" data-msg="Request Demo">Request Demo</button>
                            <button class="quick-reply" data-msg="Contact Support">Contact Support</button>
                        </div>

                        <div class="input-area">
                            <input id="user-input" type="text" placeholder="Type your message..." />
                            <button id="send-msg-btn">Send</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bootstrap JS -->
            <script
                src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

            <!-- Chatbot JavaScript -->
            <script type="text/javascript" src="/customer_support/static/src/js/portal_chatbot.js"></script>

            <!-- Handle ?tab=reporting redirect on dashboard -->
            <script type="text/javascript">
                //<![CDATA[
                document.addEventListener('DOMContentLoaded', function () {
                    var params = new URLSearchParams(window.location.search);
                    if (params.get('tab') === 'reporting') {
                        var reportingNav = document.getElementById('portalReportingNav');
                        if (reportingNav) reportingNav.click();
                    }
                });
                //]]>
            </script>

            <!-- Notification Bell JS -->
            <script type="text/javascript">
                //<![CDATA[
            (function () {
                var bell      = document.getElementById('chatbotNotifBell');
                var dropdown  = document.getElementById('chatbotNotifDropdown');
                var badge     = document.getElementById('chatbotNotifBadge');
                var notifList = document.getElementById('chatbotNotifList');
                if (bell && dropdown) {
                    bell.addEventListener('click', function (e) { e.stopPropagation(); dropdown.classList.toggle('open'); });
                    document.addEventListener('click', function () { dropdown.classList.remove('open'); });
                    dropdown.addEventListener('click', function (e) { e.stopPropagation(); });
                }
                var markReadBtn = document.getElementById('chatbotMarkRead');
                if (markReadBtn) {
                    markReadBtn.addEventListener('click', function () {
                        fetch('/customer_support/customer/notifications/mark_read', { method: 'POST', credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                        .then(function () {
                            if (badge) { badge.classList.add('d-none'); badge.textContent = '0'; }
                            if (notifList) { notifList.innerHTML = '<div class="notif-empty"><i class="bi bi-check-circle-fill" style="font-size:2rem;color:#22c55e;display:block;margin-bottom:.5rem;"></i>All caught up!</div>'; }
                        });
                    });
                }
                function sanitise(str) { var d = document.createElement('div'); d.textContent = String(str || ''); return d.innerHTML; }
                function renderNotifications(items) {
                    if (!notifList) return;
                    if (!items || !items.length) {
                        notifList.innerHTML = '<div class="notif-empty"><i class="bi bi-check-circle-fill" style="font-size:2rem;color:#22c55e;display:block;margin-bottom:.5rem;"></i>No new notifications</div>';
                        if (badge) badge.classList.add('d-none');
                        return;
                    }
                    if (badge) { badge.textContent = items.length; badge.classList.remove('d-none'); }
                    var typeLabels = { status_change: 'Status Update', assigned: 'Assigned', sla_breach: 'SLA Breach' };
                    notifList.innerHTML = items.map(function (n) {
                        var cls        = sanitise(n.cls   || 'status');
                        var icon       = sanitise(n.icon  || 'bi-bell-fill');
                        var ticketName = sanitise(n.ticket_name || (n.ticket_id ? '#' + n.ticket_id : ''));
                        var typeLabel  = sanitise(typeLabels[n.type] || 'Notification');
                        var msg        = sanitise(n.message || '');
                        var time       = sanitise(n.time   || '');
                        var title      = ticketName ? ticketName + ' \u00b7 ' + typeLabel : typeLabel;
                        return '<div class="notif-item">'
                            + '<div class="notif-icon-wrap ' + cls + '"><i class="bi ' + icon + '"></i></div>'
                            + '<div class="notif-body">'
                            + '<div class="notif-title">' + title + '</div>'
                            + '<div class="notif-sub">' + msg + '</div>'
                            + '<div class="notif-time-text">' + time + '</div>'
                            + '</div>'
                            + '<div class="notif-dot ' + cls + '"></div>'
                            + '</div>';
                    }).join('');
                }
                function loadNotifications() {
                    fetch('/customer_support/customer/notifications', { method: 'GET', credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) { renderNotifications(data.notifications || []); })
                    .catch(function () { renderNotifications([]); });
                }
                loadNotifications();
                setInterval(loadNotifications, 30000);
            })();
            //]]>
            </script>
        </t>
    </template>
</odoo>