<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="system_configuration_template" name="System Configuration">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
                    rel="stylesheet" />
                <link rel="stylesheet"
                    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
                <link
                    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap"
                    rel="stylesheet" />
                <link rel="stylesheet"
                    href="/customer_support/static/src/css/project_configuration.css?v=2" />
                <style>
                    /* No-sidebar layout overrides */
                    body { overflow: hidden; }
                    .pcs-layout { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
                    .pcs-topbar {
                        display: flex; align-items: center; justify-content: space-between;
                        padding: .85rem 2rem; background: #fff;
                        border-bottom: 1px solid #e5e7eb;
                        box-shadow: 0 1px 4px rgba(0,0,0,.06);
                        flex-shrink: 0;
                    }
                    .pcs-topbar-left { display: flex; align-items: center; gap: 1rem; min-width: 0; }
                    .pcs-topbar-step {
                        width: 36px; height: 36px; border-radius: 10px;
                        background: #065f46; color: #fff;
                        display: flex; align-items: center; justify-content: center;
                        font-size: .88rem; flex-shrink: 0;
                        box-shadow: 0 3px 10px rgba(5,150,105,.3);
                    }
                    .pcs-topbar-title { font-size: 1.05rem; font-weight: 700; color: #047857; margin: 0; line-height: 1.2; }
                    .pcs-topbar-desc  { font-size: .78rem; color: #9ca3af; margin: .12rem 0 0; }
                    .pcs-back-btn {
                        display: inline-flex; align-items: center; gap: .45rem;
                        padding: .45rem 1rem; border-radius: 8px;
                        border: 1.5px solid #e5e7eb; background: #fff;
                        color: #4b5563; font-size: .82rem; font-weight: 600;
                        text-decoration: none; transition: all .18s; white-space: nowrap;
                    }
                    .pcs-back-btn:hover {
                        border-color: #065f46; color: #065f46; background: rgba(5,150,105,.04);
                        text-decoration: none;
                    }
                    .pcs-scroll {
                        flex: 1; overflow-y: auto; padding: 2rem;
                        scrollbar-width: thin; scrollbar-color: #e5e7eb transparent;
                    }
                    .pcs-form-wrap { max-width: 820px; margin: 0 auto; }
                </style>
            </t>

            <div class="pcs-layout">

                <!-- ── Top bar ───────────────────────────────────────── -->
                <div class="pcs-topbar">
                    <div class="pcs-topbar-left">
                        <div class="pcs-topbar-step">
                            <i class="bi bi-folder-plus"></i>
                        </div>
                        <div>
                            <h1 class="pcs-topbar-title">Configure New Project</h1>
                            <p class="pcs-topbar-desc">Define project details, technology stack, timeline and compliance requirements</p>
                        </div>
                    </div>
                    <a href="/customer_support/admin_dashboard?tab=system-configuration"
                       class="pcs-back-btn">
                        <i class="bi bi-arrow-left"></i> Back to Projects
                    </a>
                </div>

                <!-- ── Scrollable content ─────────���──────────────────── -->
                <div class="pcs-scroll">
                    <div class="pcs-form-wrap">

                        <!-- Error alert (only errors redirect back here) -->
                        <t t-if="request.params.get('error')">
                            <div class="pc-alert pc-alert-danger" style="margin-bottom:1.25rem">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span><t t-esc="request.params.get('error_msg', 'An error occurred.')" /></span>
                                <button class="pc-alert-close" onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>
                            </div>
                        </t>

                        <!-- ── Project Form ───────────────────────────── -->
                        <form id="projectConfigForm" method="post"
                            action="/customer_support/admin_dashboard/projects/create"
                            class="pc-form">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />

                            <!-- Basic Information -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-info-circle-fill"></i> Basic Information
                                </div>
                                <div class="pc-grid-2">
                                    <div class="pc-field pc-span-2">
                                        <label class="pc-label" for="project_name">Project Name <span class="pc-required">*</span></label>
                                        <input type="text" class="pc-input" id="project_name" name="project_name"
                                            placeholder="e.g. Customer Portal v2" required="required" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="project_key">Project Key <span class="pc-required">*</span></label>
                                        <input type="text" class="pc-input pc-mono" id="project_key" name="project_key"
                                            placeholder="e.g. CP-2024" pattern="[A-Za-z0-9-]+" required="required" />
                                        <span class="pc-hint">Short unique identifier — auto-uppercased</span>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="project_type">Project Type <span class="pc-required">*</span></label>
                                        <select class="pc-select" id="project_type" name="project_type" required="required">
                                            <option value="">Select type...</option>
                                            <option value="web_app">Web Application</option>
                                            <option value="mobile">Mobile Application</option>
                                            <option value="machine_learning">Machine Learning</option>
                                            <option value="iot">IoT Platform</option>
                                            <option value="api">API / Backend Service</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field pc-span-2">
                                        <label class="pc-label" for="project_goals">Goals &amp; Objectives</label>
                                        <textarea class="pc-input pc-textarea" id="project_goals" name="project_goals"
                                            placeholder="Describe the project's purpose and expected outcomes..."></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Technology Stack -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-code-slash"></i> Technology Stack
                                </div>
                                <div class="pc-grid-3">
                                    <div class="pc-field">
                                        <label class="pc-label" for="programming_languages">Programming Language</label>
                                        <select class="pc-select" id="programming_languages" name="programming_languages">
                                            <option value="">Select language...</option>
                                            <option value="python">Python</option>
                                            <option value="javascript">JavaScript</option>
                                            <option value="typescript">TypeScript</option>
                                            <option value="java">Java</option>
                                            <option value="csharp">C#</option>
                                            <option value="cpp">C++</option>
                                            <option value="go">Go</option>
                                            <option value="rust">Rust</option>
                                            <option value="php">PHP</option>
                                            <option value="ruby">Ruby</option>
                                            <option value="swift">Swift</option>
                                            <option value="kotlin">Kotlin</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="frameworks">Framework</label>
                                        <select class="pc-select" id="frameworks" name="frameworks">
                                            <option value="">Select framework...</option>
                                            <optgroup label="Frontend">
                                                <option value="react">React</option>
                                                <option value="vue">Vue.js</option>
                                                <option value="angular">Angular</option>
                                                <option value="svelte">Svelte</option>
                                                <option value="nextjs">Next.js</option>
                                            </optgroup>
                                            <optgroup label="Backend">
                                                <option value="django">Django</option>
                                                <option value="fastapi">FastAPI</option>
                                                <option value="flask">Flask</option>
                                                <option value="spring">Spring Boot</option>
                                                <option value="express">Express.js</option>
                                                <option value="laravel">Laravel</option>
                                                <option value="rails">Ruby on Rails</option>
                                                <option value="odoo">Odoo</option>
                                            </optgroup>
                                            <optgroup label="Mobile">
                                                <option value="flutter">Flutter</option>
                                                <option value="react_native">React Native</option>
                                                <option value="xamarin">Xamarin</option>
                                            </optgroup>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="databases">Database</label>
                                        <select class="pc-select" id="databases" name="databases">
                                            <option value="">Select database...</option>
                                            <optgroup label="Relational">
                                                <option value="postgresql">PostgreSQL</option>
                                                <option value="mysql">MySQL</option>
                                                <option value="mssql">SQL Server</option>
                                                <option value="sqlite">SQLite</option>
                                                <option value="oracle">Oracle</option>
                                            </optgroup>
                                            <optgroup label="NoSQL">
                                                <option value="mongodb">MongoDB</option>
                                                <option value="redis">Redis</option>
                                                <option value="cassandra">Cassandra</option>
                                                <option value="firebase">Firebase</option>
                                                <option value="dynamodb">DynamoDB</option>
                                            </optgroup>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Timeline and Warranty -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-calendar-range"></i> Timeline &amp; Warranty
                                </div>
                                <div class="pc-grid-3">
                                    <div class="pc-field">
                                        <label class="pc-label" for="start_date">Start Date <span class="pc-required">*</span></label>
                                        <input type="date" class="pc-input" id="start_date" name="start_date" required="required" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="end_date">Project End Date</label>
                                        <input type="date" class="pc-input" id="end_date" name="end_date" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="warranty_months">
                                            Warranty Period <span class="pc-required">*</span>
                                            <span class="pc-tooltip" title="After this period ends, support agents are not responsible for reported issues.">
                                                <i class="bi bi-question-circle-fill"></i>
                                            </span>
                                        </label>
                                        <select class="pc-select" id="warranty_months" name="warranty_months" required="required">
                                            <option value="">Select period...</option>
                                            <option value="1">1 Month</option>
                                            <option value="3">3 Months</option>
                                            <option value="6">6 Months</option>
                                            <option value="12">12 Months (1 Year)</option>
                                            <option value="18">18 Months</option>
                                            <option value="24">24 Months (2 Years)</option>
                                            <option value="36">36 Months (3 Years)</option>
                                        </select>
                                        <span class="pc-hint" id="warranty_expiry_hint"></span>
                                    </div>
                                </div>
                                <div class="pc-warranty-notice" id="warranty_notice" style="display:none">
                                    <i class="bi bi-shield-check"></i>
                                    <div>
                                        <strong>Warranty Coverage Active</strong>
                                        <span id="warranty_notice_text"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Compliance Requirements -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-patch-check-fill"></i> Compliance Requirements
                                </div>
                                <div class="pc-compliance-grid">
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_gdpr" value="gdpr" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">GDPR</span>
                                            <span class="pc-compliance-desc">Data Protection</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_hipaa" value="hipaa" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">HIPAA</span>
                                            <span class="pc-compliance-desc">Healthcare</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_pci_dss" value="pci_dss" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">PCI DSS</span>
                                            <span class="pc-compliance-desc">Payment Security</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_iso27001" value="iso27001" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">ISO 27001</span>
                                            <span class="pc-compliance-desc">Security Standard</span>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="pc-actions">
                                <button type="reset" class="pc-btn pc-btn-secondary"
                                    title="Reset form to default values">
                                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                                </button>
                                <button type="submit" class="pc-btn pc-btn-primary"
                                    title="Save project configuration">
                                    <i class="bi bi-check2-circle"></i> Save Project
                                </button>
                            </div>

                        </form>
                    </div><!-- /pcs-form-wrap -->
                </div><!-- /pcs-scroll -->

            </div><!-- /pcs-layout -->

            <script>
            //<![CDATA[
            (function () {

                // Warranty calculator
                var warrantySelect = document.getElementById('warranty_months');
                var endDateInput   = document.getElementById('end_date');
                var hint           = document.getElementById('warranty_expiry_hint');
                var notice         = document.getElementById('warranty_notice');
                var noticeText     = document.getElementById('warranty_notice_text');

                function updateWarranty() {
                    var months = parseInt(warrantySelect.value);
                    var endVal = endDateInput.value;
                    if (!months || !endVal) { hint.textContent = ''; notice.style.display = 'none'; return; }
                    var base = new Date(endVal);
                    base.setMonth(base.getMonth() + months);
                    var exp = base.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                    hint.textContent = 'Coverage expires: ' + exp;
                    noticeText.textContent = ' — Support agents are responsible for issues until ' + exp + '. Tickets raised after this date may be declined.';
                    notice.style.display = 'flex';
                }

                if (warrantySelect) warrantySelect.addEventListener('change', updateWarranty);
                if (endDateInput)   endDateInput.addEventListener('change', updateWarranty);

                // Auto-uppercase project key
                var keyInput = document.getElementById('project_key');
                if (keyInput) {
                    keyInput.addEventListener('input', function () {
                        var pos = this.selectionStart;
                        this.value = this.value.toUpperCase().replace(/[^A-Z0-9-]/g, '');
                        this.setSelectionRange(pos, pos);
                    });
                }

                // Start/end date relationship
                var startDate = document.getElementById('start_date');
                var endDate   = document.getElementById('end_date');
                if (startDate && endDate) {
                    startDate.addEventListener('change', function () { endDate.min = this.value; });
                    endDate.addEventListener('change', function () {
                        if (startDate.value && this.value < startDate.value) {
                            this.setCustomValidity('End date must be after start date');
                        } else {
                            this.setCustomValidity('');
                        }
                    });
                }

                // Loading state on submit
                var form = document.getElementById('projectConfigForm');
                if (form) {
                    form.addEventListener('submit', function (e) {
                        if (!form.checkValidity()) {
                            e.preventDefault();
                            form.classList.add('was-validated');
                            return;
                        }
                        var btn = form.querySelector('button[type="submit"]');
                        if (btn) {
                            btn.disabled = true;
                            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:13px;height:13px"></span>Saving…';
                        }
                    });
                }

                // Auto-dismiss error alert
                document.querySelectorAll('.pc-alert').forEach(function (a) {
                    setTimeout(function () {
                        a.style.transition = 'opacity .4s';
                        a.style.opacity = '0';
                        setTimeout(function () { a.remove(); }, 420);
                    }, 7000);
                });

            })();
            //]]>
            </script>

        </t>
    </template>
</odoo>
