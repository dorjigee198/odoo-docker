<odoo>
    <template id="portal_login_page" name="Customer Support Login">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
                <!--  Bootstrap 5 CSS  -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <!--  Custom CSS  -->
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_login.css?v=4"/>
            </t>

            <div class="login-container container-fluid p-0">
                <div class="row g-0">

                    <!--  Left Section - Brand Highlights  -->
                    <div class="left-section col-lg-6 d-flex align-items-stretch d-none d-lg-flex">
                        <div class="brand-panel w-100">
                            <div class="background-pattern"/>

                            <!--  Feature Highlights  -->
                            <div class="features-list">
                                <div class="feature-item">
                                    <div class="feature-icon-wrap">
                                        <i class="bi bi-ticket-detailed-fill"/>
                                    </div>
                                    <div class="feature-content">
                                        <h4 class="feature-title">Real-Time Ticket Tracking</h4>
                                        <p class="feature-desc">Monitor every support request from open to resolved, instantly.</p>
                                    </div>
                                </div>
                                <div class="feature-item">
                                    <div class="feature-icon-wrap">
                                        <i class="bi bi-lightning-charge-fill"/>
                                    </div>
                                    <div class="feature-content">
                                        <h4 class="feature-title">Fast Response Times</h4>
                                        <p class="feature-desc">Clear SLA tracking ensures your issues are resolved on time.</p>
                                    </div>
                                </div>
                                <div class="feature-item">
                                    <div class="feature-icon-wrap">
                                        <i class="bi bi-chat-dots-fill"/>
                                    </div>
                                    <div class="feature-content">
                                        <h4 class="feature-title">AI-Powered FAQ</h4>
                                        <p class="feature-desc">Get instant answers anytime with our intelligent chatbot.</p>
                                    </div>
                                </div>
                                <div class="feature-item">
                                    <div class="feature-icon-wrap">
                                        <i class="bi bi-bar-chart-fill"/>
                                    </div>
                                    <div class="feature-content">
                                        <h4 class="feature-title">Detailed Reports</h4>
                                        <p class="feature-desc">Access comprehensive analytics on all your support interactions.</p>
                                    </div>
                                </div>
                            </div>

                            <!--  Stats  -->
                            <div class="brand-stats">
                                <div class="brand-stat">
                                    <span class="stat-value">3.2k+</span>
                                    <span class="stat-label">Tickets Resolved</span>
                                </div>
                                <div class="brand-stat-divider"/>
                                <div class="brand-stat">
                                    <span class="stat-value">&lt;2h</span>
                                    <span class="stat-label">Avg Response</span>
                                </div>
                                <div class="brand-stat-divider"/>
                                <div class="brand-stat">
                                    <span class="stat-value">24/7</span>
                                    <span class="stat-label">Availability</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!--  Right Section - Login Form  -->
                    <div class="right-section col-12 col-lg-6 d-flex align-items-stretch">
                        <div class="background-overlay"/>
                        <div class="login-form-container w-100">
                            <div class="login-box">

                                <!--  Logo  -->
                                <div class="logo-section">
                                    <div class="logo-container">
                                        <div class="logo-circle">
                                            <img src="/customer_support/static/src/img/images.png" alt="Logo" class="logo-img"/>
                                        </div>
                                    </div>
                                    <h2 class="login-title">Login to your account</h2>
                                </div>

                                <!--  Error Message  -->
                                <div class="error-message" t-if="error">
                                    <t t-esc="error"/>
                                </div>
                                <div class="alert alert-success" t-if="success">
                                    <t t-esc="success"/>
                                </div>

                                <!--  Login Form  -->
                                <form action="/customer_support/authenticate" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <!-- ← ADDED: passes the redirect URL through the form so
                                         after login the customer lands back on their ticket -->
                                    <input type="hidden" name="redirect" t-att-value="redirect or ''"/>

                                    <!--  Email Input  -->
                                    <div class="input-group-custom">
                                        <label for="email" class="form-label">Email Address</label>
                                        <div class="position-relative">
                                            <input type="email" id="email" name="email"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Enter your email"
                                                required="required"
                                                autocomplete="email"/>
                                            <i class="bi bi-envelope-fill input-icon"/>
                                        </div>
                                    </div>

                                    <!--  Password Input  -->
                                    <div class="input-group-custom">
                                        <label for="password" class="form-label">Password</label>
                                        <div class="position-relative">
                                            <input type="password" id="password" name="password"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Enter your password"
                                                required="required"
                                                autocomplete="current-password"/>
                                            <i class="bi bi-lock-fill input-icon"/>
                                            <button type="button" class="password-toggle-btn" onclick="togglePassword()">
                                                <i class="bi bi-eye-fill"/>
                                            </button>
                                        </div>
                                    </div>

                                    <!--  Forgot/Reset Links  -->
                                    <div class="login-links">
                                        <a href="/customer_support/forgot_password" class="text-decoration-none">Forgot password?</a>
                                    </div>

                                    <!--  Submit Button  -->
                                    <button type="submit" class="submit-btn">
                                        <span>Sign in</span>
                                    </button>

                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!--  Bootstrap JS Bundle  -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"/>
            <!--  Custom JavaScript  -->
            <script src="/customer_support/static/src/js/portal_login.js"/>
            <script>
                //<![CDATA[
                var _params = new URLSearchParams(window.location.search || '');
                var _fromLogout = _params.get('from_logout') === '1';

                if (_fromLogout) {
                    // Build an explicit local history pair:
                    // previous entry = landing, current entry = login.
                    // This makes a single browser-back go to landing reliably.
                    history.replaceState({ from_logout_landing: true }, '', '/customer_support/');
                    history.pushState({ from_logout_login: true }, '', window.location.href);
                }

                // bfcache guard: reload if browser restores this page while authenticated
                window.addEventListener('pageshow', function (e) {
                    if (e.persisted) { window.location.reload(); }
                });

                // Back-button guard after logout: always send user to landing page.
                window.addEventListener('popstate', function (e) {
                    if (_fromLogout || (e.state && e.state.from_logout_landing)) {
                        window.location.replace('/customer_support/');
                        return;
                    }

                    // Existing guard: if back/forward navigates outside the portal
                    // (e.g. to /web/login), redirect to landing page.
                    if (!window.location.pathname.startsWith('/customer_support/')) {
                        window.location.replace('/customer_support/');
                    }
                });
                //]]>
            </script>

        </t>
    </template>
</odoo>
