<odoo>
    <template id="forgot_password_page" name="Customer Support Forgot Password">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_login.css"/>
            </t>

            <div class="login-container container-fluid p-0 recovery-page">
                <div class="row g-0 min-vh-100">
                    <div class="col-12 d-flex align-items-center justify-content-center p-4">
                        <div class="login-box recovery-card">
                            <div class="logo-section">
                                <div class="recovery-icon-wrap">
                                    <i class="bi bi-shield-lock-fill"></i>
                                </div>
                                <p class="recovery-eyebrow">ACCOUNT RECOVERY</p>
                                <h2 class="login-title mb-2">Forgot Password</h2>
                                <p class="text-muted mb-0">Enter your email and we will send a secure reset link.</p>
                            </div>

                            <div class="error-message" t-if="error">
                                <t t-esc="error"/>
                            </div>
                            <div class="alert alert-success" t-if="message">
                                <t t-esc="message"/>
                            </div>

                            <form action="/customer_support/forgot_password" method="post" t-if="not message">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="input-group-custom">
                                    <label for="login" class="form-label">Email Address</label>
                                    <div class="position-relative">
                                        <input type="email" id="login" name="login"
                                            class="form-control form-control-custom ps-5"
                                            placeholder="Enter your email"
                                            t-att-value="login or ''"
                                            required="required"/>
                                        <i class="bi bi-envelope-fill input-icon"/>
                                    </div>
                                </div>

                                <button type="submit" class="submit-btn">
                                    <span>Send Reset Link</span>
                                </button>
                            </form>

                            <div class="recovery-note" t-if="not message">
                                <i class="bi bi-info-circle"></i>
                                <span>For security, we show the same response whether or not the account exists.</span>
                            </div>

                            <div class="login-links mt-3">
                                <a href="/customer_support/login" class="text-decoration-none">Back to login</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="reset_password_page" name="Customer Support Reset Password">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_login.css"/>
            </t>

            <div class="login-container container-fluid p-0 recovery-page">
                <div class="row g-0 min-vh-100">
                    <div class="col-12 d-flex align-items-center justify-content-center p-4">
                        <div class="login-box recovery-card">
                            <div class="logo-section">
                                <div class="recovery-icon-wrap">
                                    <i class="bi bi-key-fill"></i>
                                </div>
                                <p class="recovery-eyebrow">PASSWORD UPDATE</p>
                                <h2 class="login-title mb-2">Reset Password</h2>
                                <p class="text-muted mb-0">Set your new password to continue.</p>
                            </div>

                            <t t-if="invalid_token">
                                <div class="alert alert-danger mb-3">This reset link is invalid or expired.</div>
                                <div class="login-links mt-3">
                                    <a href="/customer_support/forgot_password" class="text-decoration-none">Request a new reset link</a>
                                </div>
                            </t>

                            <t t-if="not invalid_token">
                                <div class="error-message" t-if="error">
                                    <t t-esc="error"/>
                                </div>
                                <div class="alert alert-success" t-if="message">
                                    <t t-esc="message"/>
                                </div>

                                <form t-attf-action="/customer_support/reset_password?db={{ request.session.db or request.env.cr.dbname }}" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="token" t-att-value="token"/>

                                    <div class="input-group-custom">
                                        <label for="password" class="form-label">New Password</label>
                                        <div class="position-relative">
                                            <input type="password" id="password" name="password"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Enter new password"
                                                required="required"
                                                minlength="8"
                                                autocomplete="new-password"/>
                                            <i class="bi bi-lock-fill input-icon"/>
                                        </div>
                                    </div>

                                    <div class="input-group-custom">
                                        <label for="confirm_password" class="form-label">Confirm Password</label>
                                        <div class="position-relative">
                                            <input type="password" id="confirm_password" name="confirm_password"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Confirm new password"
                                                required="required"
                                                minlength="8"
                                                autocomplete="new-password"/>
                                            <i class="bi bi-shield-lock-fill input-icon"/>
                                        </div>
                                    </div>

                                    <button type="submit" class="submit-btn">
                                        <span>Update Password</span>
                                    </button>
                                </form>

                                <div class="recovery-note">
                                    <i class="bi bi-shield-check"></i>
                                    <span>Use at least 8 characters and avoid reusing old passwords.</span>
                                </div>
                            </t>

                            <div class="login-links mt-3">
                                <a href="/customer_support/login" class="text-decoration-none">Back to login</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
